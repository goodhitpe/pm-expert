**해설:**

**완성된 코드:**

```python
# subnet_calculator.py
import ipaddress
import math

def calculate_required_size(hosts, overhead_percent=30):
    """여유율을 포함한 필요 호스트 수 계산"""
    return int(hosts * (1 + overhead_percent / 100))

def find_suitable_prefix(required_hosts):
    """필요한 호스트 수를 수용할 수 있는 prefix 길이 찾기"""
    # 2^n - 2 >= required_hosts 를 만족하는 최소 n 찾기
    # -2는 네트워크 주소와 브로드캐스트 주소 제외
    
    for prefix in range(32, 0, -1):
        available_hosts = 2 ** (32 - prefix) - 2
        if available_hosts >= required_hosts:
            return prefix
    return None

def calculate_subnet(network_str, required_hosts):
    """서브넷 정보 계산"""
    base_network = ipaddress.IPv4Network(network_str, strict=False)
    prefix = find_suitable_prefix(required_hosts)
    
    if prefix is None:
        return None
    
    # 서브넷 생성
    subnet = ipaddress.IPv4Network(f"{base_network.network_address}/{prefix}", strict=False)
    
    # 사용 가능한 호스트 수
    usable_hosts = subnet.num_addresses - 2
    
    # 첫 번째와 마지막 사용 가능 IP
    first_usable = subnet.network_address + 1
    last_usable = subnet.broadcast_address - 1
    
    return {
        'network': str(subnet.network_address),
        'prefix': prefix,
        'subnet_mask': str(subnet.netmask),
        'broadcast': str(subnet.broadcast_address),
        'first_usable': str(first_usable),
        'last_usable': str(last_usable),
        'usable_hosts': usable_hosts,
    }

def create_ip_plan(base_network, departments):
    """부서별 IP 할당 계획 생성"""
    print("="*80)
    print("IP 주소 할당 계획서")
    print("="*80)
    print(f"전체 네트워크: {base_network}\n")
    
    # 필요 호스트 수 내림차순 정렬 (큰 서브넷부터 할당)
    sorted_deps = sorted(departments.items(), key=lambda x: x[1], reverse=True)
    
    base_net = ipaddress.IPv4Network(base_network)
    current_address = base_net.network_address
    
    allocations = []
    
    for dept_name, required in sorted_deps:
        # 여유율 30% 추가
        with_overhead = calculate_required_size(required, 30)
        
        print(f"\n[{dept_name}]")
        print(f"  요구 사항: {required}명")
        print(f"  여유율 30% 포함: {with_overhead}명")
        
        # 적절한 서브넷 찾기
        prefix = find_suitable_prefix(with_overhead)
        subnet_size = 32 - prefix
        
        # 현재 주소에서 서브넷 생성
        subnet = ipaddress.IPv4Network(f"{current_address}/{prefix}", strict=False)
        
        # 정보 계산
        usable = subnet.num_addresses - 2
        first_usable = subnet.network_address + 1
        last_usable = subnet.broadcast_address - 1
        
        print(f"  ─────────────────────────────────────")
        print(f"  네트워크 주소: {subnet.network_address}/{prefix}")
        print(f"  서브넷 마스크: {subnet.netmask}")
        print(f"  브로드캐스트: {subnet.broadcast_address}")
        print(f"  사용 가능 범위: {first_usable} ~ {last_usable}")
        print(f"  사용 가능 호스트: {usable}개")
        print(f"  활용률: {required}/{usable} = {required/usable*100:.1f}%")
        
        allocations.append({
            'department': dept_name,
            'required': required,
            'allocated': usable,
            'network': f"{subnet.network_address}/{prefix}",
        })
        
        # 다음 서브넷을 위해 주소 이동
        current_address = subnet.broadcast_address + 1
    
    # 요약 테이블
    print("\n" + "="*80)
    print("할당 요약")
    print("="*80)
    print(f"{'부서':<15} {'요구':<10} {'할당':<10} {'네트워크':<25} {'활용률':<10}")
    print("-"*80)
    
    for alloc in allocations:
        utilization = f"{alloc['required']/alloc['allocated']*100:.1f}%"
        print(f"{alloc['department']:<15} {alloc['required']:<10} {alloc['allocated']:<10} {alloc['network']:<25} {utilization:<10}")
    
    print("="*80)
    
    # 전체 사용률
    total_required = sum([d['required'] for d in allocations])
    total_allocated = sum([d['allocated'] for d in allocations])
    print(f"\n전체 요구: {total_required}")
    print(f"전체 할당: {total_allocated}")
    print(f"전체 활용률: {total_required/total_allocated*100:.1f}%")
    print(f"전체 네트워크 사용: {current_address} / {base_net.broadcast_address}")

if __name__ == '__main__':
    base_network = '192.168.0.0/16'
    
    departments = {
        '개발팀': 100,
        '영업팀': 50,
        '마케팅': 30,
        '관리팀': 20,
        '서버팜': 10,
    }
    
    create_ip_plan(base_network, departments)
```

