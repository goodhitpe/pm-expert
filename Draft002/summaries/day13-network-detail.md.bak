**해설:**

**완성된 코드:**

```python
# port_scanner.py
import socket
from datetime import datetime

COMMON_PORTS = {
    21: 'FTP',
    22: 'SSH',
    23: 'Telnet',
    25: 'SMTP',
    53: 'DNS',
    80: 'HTTP',
    110: 'POP3',
    143: 'IMAP',
    443: 'HTTPS',
    3306: 'MySQL',
    3389: 'RDP',
    5432: 'PostgreSQL',
    5672: 'RabbitMQ',
    6379: 'Redis',
    8080: 'HTTP-Alt',
    8443: 'HTTPS-Alt',
    27017: 'MongoDB',
}

def scan_port(host, port, timeout=1):
    """포트가 열려있는지 확인"""
    try:
        # TCP 소켓 생성
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(timeout)
        
        # 연결 시도
        result = sock.connect_ex((host, port))
        sock.close()
        
        # connect_ex 반환값: 0 = 성공, 그 외 = 실패
        return result == 0
    except socket.error:
        return False

def get_service_version(host, port):
    """서비스 배너 그래빙 (버전 정보 수집)"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(2)
        sock.connect((host, port))
        
        # 일부 서비스는 연결 시 배너 전송 (예: FTP, SMTP)
        sock.send(b'\r\n')
        banner = sock.recv(1024).decode('utf-8', errors='ignore').strip()
        sock.close()
        
        if banner and len(banner) < 100:
            return banner
    except:
        pass
    return None

def scan_host(host):
    """호스트의 주요 포트 스캔"""
    print(f"{'='*70}")
    print(f"포트 스캔 대상: {host}")
    print(f"시작 시간: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"{'='*70}\n")
    
    open_ports = []
    
    # 포트 스캔
    for port, service in sorted(COMMON_PORTS.items()):
        if scan_port(host, port, timeout=0.5):
            open_ports.append((port, service))
            print(f"[+] 포트 {port:5d} : {service:15s} - OPEN", end='')
            
            # 배너 그래빙 시도
            banner = get_service_version(host, port)
            if banner:
                print(f" ({banner[:50]})")
            else:
                print()
        else:
            print(f"[-] 포트 {port:5d} : {service:15s} - CLOSED")
    
    # 요약
    print(f"\n{'='*70}")
    print(f"스캔 완료: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"열린 포트 개수: {len(open_ports)}")
    if open_ports:
        print("\n열린 포트 목록:")
        for port, service in open_ports:
            print(f"  - {port}: {service}")
    else:
        print("열린 포트가 없습니다.")
    print(f"{'='*70}")

if __name__ == '__main__':
    target = input("스캔할 호스트 (예: localhost, scanme.nmap.org): ")
    print()
    scan_host(target)
```

